# Apple Music API Configuration
# Get credentials from: https://developer.apple.com/documentation/applemusicapi/getting_tokens_and_keys

# Required: Your Apple Developer Team ID (10 characters)
APPLE_MUSIC_TEAM_ID=

# Required: Music Kit Key ID (10 characters)
APPLE_MUSIC_KEY_ID=

# Required: Private Key (p8 format - full content including BEGIN/END lines)
# Download from Apple Developer Portal: Certificates, Identifiers & Profiles → Keys
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
YOUR_KEY_CONTENT_HERE
-----END EC PRIVATE KEY-----"

# Alternative: Path to private key file
APPLE_MUSIC_PRIVATE_KEY_PATH=/path/to/your/AuthKey.p8

# Required: Apple Music Storefront (e.g., "us", "gb", "jp")
APPLE_MUSIC_STOREFRONT=us

# Optional: Base URL (default: https://api.music.apple.com)
# APPLE_MUSIC_BASE_URL=https://api.music.apple.com

# Optional: Token TTL in seconds (default: 600 = 10 minutes)
# APPLE_MUSIC_TOKEN_TTL_SECONDS=600

# Optional: Req options for HTTP client (JSON format)
# APPLE_MUSIC_REQ_OPTIONS={"timeout": 30000}
